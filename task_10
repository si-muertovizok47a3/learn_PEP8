import time


def timer(func):
    def wrapper(*args, **kwargs):
        start = time.time()
        result = func(*args, **kwargs)
        end = time.time()
        print(f"Function {func.__name__} took {end - start:.4f} seconds")
        return result

    return wrapper


@timer
def heavy_computation(n):
    return sum(i * i for i in range(n))


